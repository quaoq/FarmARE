# Copy this file to `.env` and fill only what you need.
# Default workflow for quick validation is mock mode (no API keys required).

# Optional: OpenAI (for real model runs)
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Optional: Hugging Face inference providers
HF_TOKEN=
HF_INFERENCE_TOKEN=
HF_BILL_TO=

# Optional: DeepSeek (if provider=deepseek)
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# Optional: Llama API (if provider=llama-api)
# Note: suite real-mode can also bridge OPENAI_* into LLAMA_* automatically.
LLAMA_API_KEY=
LLAMA_API_BASE=https://api.llama.com/compat/v1

# Optional: local endpoint
LOCAL_LLM_ENDPOINT=
